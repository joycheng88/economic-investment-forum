# GLP-1 Data Ingestion Pipeline Configuration
# Copy this file to .env and fill in your API credentials

# ========================
# NewsAPI Configuration
# ========================
# Get your free API key from: https://newsapi.org
# Free tier: 450 requests/day
NEWS_API_KEY=your_newsapi_key_here

# ========================
# Reddit (PRAW) Configuration
# ========================
# Register your app at: https://www.reddit.com/prefs/apps
# Select: "script" app type
# You'll need BOTH client_id and client_secret

REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=glp1_sentiment_analysis_v1.0

# Optional: Customize user agent with your username
# Format: "platform:app_name:version (by /u/your_username)"
# Example: "linux:glp1_sentiment:1.0 (by /u/joycheng)"
